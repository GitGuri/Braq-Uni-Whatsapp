# ─────────────────────────────────────────────
# Braq Uni – Braq Connect™ API
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://your-api-domain.com

# PostgreSQL (Supabase)
# Find these under Project Settings -> Database -> Connection info.
# Use the direct connection (port 5432) for this app, not the pooler (6543) —
# this is a single long-lived Node process with its own pg.Pool, not a
# serverless/edge function that needs Supavisor's connection pooling.
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_SSL=true

# Meta Cloud API (WhatsApp)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_TOKEN=your_permanent_access_token
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_string
META_API_VERSION=v20.0

# JWT Auth (Staff Dashboard)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=8h

# Gemini API (AI-grounded FAQ + quotation parsing) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Logging
LOG_LEVEL=info
