# ─────────────────────────────────────────────
# Braq Uni – Braq Connect™ API
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://your-api-domain.com

# PostgreSQL (Supabase)
# Copy the transaction pooler connection string from:
# Project Settings → Database → Connection string → Transaction pooler (port 6543)
# URL-encode any special chars in your password (e.g. @ → %40)
# Append ?family=4 to force IPv4 and avoid timeout issues
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-xx-region.pooler.supabase.com:6543/postgres?family=4

# Meta Cloud API (WhatsApp)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_TOKEN=your_permanent_access_token
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_string
META_API_VERSION=v20.0

# JWT Auth (Staff Dashboard)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=8h

# Gemini API (AI-grounded FAQ + quotation parsing) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Resend (Consultant Email Notifications)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# Once braquni.com is verified at resend.com/domains, use:
FROM_EMAIL=notifications@braquni.com
# Temporary override: set this to YOUR email to receive all notifications while domain is unverified
# NOTIFICATION_OVERRIDE_EMAIL=your@email.com
DASHBOARD_BASE_URL=https://your-dashboard-domain.com

# Logging
LOG_LEVEL=info
